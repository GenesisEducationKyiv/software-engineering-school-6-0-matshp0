{
  "name": "@github-notifier/contracts",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "exports": {
    "./mailer/messaging": {
      "types": "./dist/mailer/messaging/index.d.ts",
      "default": "./dist/mailer/messaging/index.js"
    },
    "./verification/http": {
      "types": "./dist/verification/http/index.d.ts",
      "default": "./dist/verification/http/index.js"
    },
    "./verification/grpc": {
      "types": "./dist/verification/grpc/index.d.ts",
      "default": "./dist/verification/grpc/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "proto:lint": "buf lint",
    "proto:generate": "buf generate",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\""
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.47.2",
    "prettier": "^3.4.2",
    "ts-proto": "^2.6.1",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.2.3",
    "@grpc/grpc-js": "^1.12.5",
    "zod": "^4.4.3"
  }
}
