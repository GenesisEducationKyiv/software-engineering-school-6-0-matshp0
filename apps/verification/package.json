{
  "name": "@github-notifier/verification",
  "version": "0.0.1",
  "description": "Mail verification microservice",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "dev": "tsx --watch=src --env-file=.env ./src/server.ts",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "db:migrate": "node --env-file=.env node_modules/.bin/prisma migrate dev",
    "db:migrate:deploy": "node --env-file=.env node_modules/.bin/prisma migrate deploy",
    "db:migrate:status": "node --env-file=.env node_modules/.bin/prisma migrate status"
  },
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/env": "^6.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/sensible": "^6.0.4",
    "@fastify/type-provider-json-schema-to-ts": "^5.0.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@github-notifier/contracts": "workspace:*",
    "@grpc/grpc-js": "^1.12.5",
    "amqplib": "^0.10.5",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "kysely": "^0.28.15",
    "pg": "^8.20.0",
    "pino-elasticsearch": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/amqplib": "^0.10.5",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.20.0",
    "@vitest/eslint-plugin": "^1.6.16",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "fastify-tsconfig": "^3.0.0",
    "globals": "^16.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "prisma": "^7.7.0",
    "tsx": "4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.4"
  }
}
