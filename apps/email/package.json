{
  "name": "@github-notifier/email",
  "version": "0.0.1",
  "description": "Email delivery microservice",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "dev": "tsx --watch=src --env-file=.env ./src/main.ts",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@github-notifier/contracts": "workspace:*",
    "amqplib": "^0.10.5",
    "nodemailer": "^8.0.5",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/amqplib": "^0.10.5",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^8.0.0",
    "@vitest/eslint-plugin": "^1.6.16",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "tsx": "4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.4"
  }
}
