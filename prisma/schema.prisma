generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Repository {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName      String         @unique @map("full_name")
  lastSeenTag   String?        @map("last_seen_tag")
  etag          String?
  lastCheckedAt DateTime?      @default(now()) @map("last_checked_at") @db.Timestamptz(6)
  subscriptions Subscription[]

  @@index([lastCheckedAt], map: "idx_repositories_last_checked")
  @@map("repositories")
}

model Subscription {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String
  repositoryId String              @map("repository_id") @db.Uuid
  status       subscription_status @default(pending)
  confirmToken String              @unique @default(dbgenerated("gen_random_uuid()")) @map("confirm_token") @db.Uuid
  unsubToken   String              @unique @default(dbgenerated("gen_random_uuid()")) @map("unsub_token") @db.Uuid
  repository   Repository          @relation(fields: [repositoryId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([email, repositoryId])
  @@index([confirmToken], map: "idx_subscriptions_confirm_token")
  @@index([unsubToken], map: "idx_subscriptions_unsub_token")
  @@map("subscriptions")
}

enum subscription_status {
  pending
  confirmed
  unsubscribed
}
